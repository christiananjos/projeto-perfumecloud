{
  "name": "perfumecloud-pro-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "PerfumeCloud Pro - frontend Vue 3 (CDN, sem build de JS). O CSS do Tailwind é gerado via CLI (build:css), o JS continua sem bundler.",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build:css": "tailwindcss -i ./assets/css/tailwind.src.css -o ./assets/css/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./assets/css/tailwind.src.css -o ./assets/css/tailwind.css --watch",
    "build": "node scripts/build-site.mjs",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "tailwindcss": "^3.4.19",
    "vitest": "^4.1.10"
  }
}
